<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml
    ─────────────────
    Layout:
      ① App title
      ② "Activity" status card  — current operation (idle / tracking / saved)
      ③ "GPS Coordinates" card  — live lat / lon
      ④ Start Tracking button   — wrap_content width
      ⑤ End Tracking button     — wrap_content width
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5"
    tools:context=".MainActivity">

    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <!-- ① App title                                                           -->
    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="GPS Location Logger"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:gravity="center"
        android:paddingTop="36dp"
        android:paddingBottom="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <!-- ② Activity status card                                                -->
    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACTIVITY"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:textColor="#888EAB"
                android:layout_marginBottom="6dp" />

            <!-- Live activity status populated by MainActivity -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text='Press "Start Tracking" to begin.'
                android:textSize="15sp"
                android:textColor="#1A1A2E"
                android:lineSpacingMultiplier="1.3"
                tools:text="Tracking in progress…" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <!-- ③ GPS Coordinates card                                                -->
    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardCoordinates"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/cardStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GPS COORDINATES"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:textColor="#888EAB"
                android:layout_marginBottom="6dp" />

            <!-- Live lat/lon populated by MainActivity -->
            <TextView
                android:id="@+id/tvCoordinates"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="–"
                android:textSize="17sp"
                android:textColor="#0F3460"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.5"
                tools:text="Lat: 12.971600&#10;Lon: 77.594600" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <!-- ④ ⑤  Buttons — sized to their text, centred as a horizontal pair      -->
    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layoutButtons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="32dp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/cardCoordinates"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.4">

        <!-- Start Tracking — enabled on launch -->
        <Button
            android:id="@+id/btnStartTracking"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Start Tracking"
            android:textSize="15sp"
            android:textStyle="bold"
            android:paddingHorizontal="28dp"
            android:paddingVertical="14dp"
            android:enabled="true"
            android:backgroundTint="#0F3460"
            android:layout_marginEnd="10dp" />

        <!-- End Tracking — disabled on launch -->
        <Button
            android:id="@+id/btnEndTracking"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="End Tracking"
            android:textSize="15sp"
            android:textStyle="bold"
            android:paddingHorizontal="28dp"
            android:paddingVertical="14dp"
            android:enabled="false"
            android:backgroundTint="#E94560"
            android:layout_marginStart="10dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
