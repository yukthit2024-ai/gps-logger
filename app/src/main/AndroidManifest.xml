<?xml version="1.0" encoding="utf-8"?>
<!--
    AndroidManifest.xml

    Permissions:
      - ACCESS_FINE_LOCATION  — precise GPS fixes (runtime permission on API 23+)
      - ACCESS_COARSE_LOCATION — required companion declaration
      - INTERNET              — not required for this app, but kept for future use

    No WRITE_EXTERNAL_STORAGE needed because we only write to app-specific
    external storage via getExternalFilesDir(), which is scoped-storage compliant.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.gpslocationlogger">

    <!-- Location permissions -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Required feature declaration so the app is not listed on devices without GPS -->
    <uses-feature
        android:name="android.hardware.location.gps"
        android:required="true" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.GPSLocationLogger">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>
