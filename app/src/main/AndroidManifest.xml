<?xml version="1.0" encoding="utf-8"?>
<!--
    AndroidManifest.xml

    Permissions:
      - ACCESS_FINE_LOCATION  — precise GPS fixes (runtime permission on API 23+)
      - ACCESS_COARSE_LOCATION — required companion declaration
      - INTERNET              — not required for this app, but kept for future use

    No WRITE_EXTERNAL_STORAGE needed because we only write to app-specific
    external storage via getExternalFilesDir(), which is scoped-storage compliant.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.gpslocationlogger">

    <!-- Location permissions -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Foreground service permissions (Required for background tracking) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <!-- Required on Android 13+ (API 33+) to show the tracking notification -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Required feature declaration so the app is not listed on devices without GPS -->
    <uses-feature
        android:name="android.hardware.location.gps"
        android:required="true" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher_img"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_launcher_img"
        android:supportsRtl="true"
        android:theme="@style/Theme.GPSLocationLogger">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:label="Options"
            android:screenOrientation="portrait"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".HelpActivity"
            android:exported="false"
            android:label="Help"
            android:screenOrientation="portrait"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".AboutActivity"
            android:exported="false"
            android:label="About"
            android:screenOrientation="portrait"
            android:parentActivityName=".MainActivity" />

        <!-- Foreground Service for Background Tracking -->
        <service
            android:name=".LocationService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="location" />

    </application>

</manifest>
